APP_NAME="Lottery LLM API"
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOWED_ORIGINS=*

# Optional. If set, frontend callers must send X-API-Key with the same value.
API_ACCESS_KEY=demo-frontend-key

# OpenAI-compatible large model gateway
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-model-api-key
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER_NAME=default
LLM_TIMEOUT_SECONDS=60

# Optional. If configured, this overrides the single-model config above.
# LLM_PROVIDERS='[{"name":"model-a","base_url":"https://api.openai.com/v1","api_key":"key-a","model":"gpt-4o-mini"},{"name":"model-b","base_url":"https://example.com/v1","api_key":"key-b","model":"qwen-plus"}]'

# Optional upstream lottery result API. The service calls GET {LOTTERY_API_URL}?game=ssq&date=YYYY-MM-DD
LOTTERY_API_URL=
LOTTERY_API_KEY=
LOTTERY_DATA_FILE=data/lottery_results.json

# If no LOTTERY_API_URL/local result is found, try built-in public official result sources.
LOTTERY_AUTO_FETCH=true

# If the requested date has no draw result, return the latest available official result instead.
LOTTERY_LATEST_IF_DATE_MISSING=true
